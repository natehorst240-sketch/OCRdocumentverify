# Copy to .env and adjust. docker-compose reads this automatically.

# Model Ollama serves. The default suits a GPU box (RTX 3060 12GB or better).
# On a CPU-only / budget box, use the smaller, faster model instead:
#   QWEN_MODEL=qwen2.5:3b
QWEN_MODEL=qwen2.5:7b

# OLLAMA_HOST is set by compose to the ollama service and normally needs no
# change. Point it at another machine to offload the LLM to a beefier box:
#   OLLAMA_HOST=http://192.168.1.50:11434

# No-LLM mode: run the deterministic pipeline with manual entry + keyword
# matching, no Ollama needed. Use this on low-RAM hosts (8 GB N100). The
# docker-compose.nollm.yml file sets this for you.
#   DISABLE_LLM=1
